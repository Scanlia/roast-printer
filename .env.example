# ===== UniFi Protect =====
PROTECT_HOST=192.168.0.1
PROTECT_USERNAME=your_username
PROTECT_PASSWORD=your_password
PROTECT_API_KEY=your_api_key
PROTECT_VERIFY_SSL=false
CAMERA_NAME=G6 Bullet

# ===== Gemini API =====
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# ===== ESP32 / Windows Printer Bridge =====
ESP32_HOST=192.168.0.100
ESP32_PORT=9100

# ===== Android Termux Print Bridge =====
ANDROID_ENABLED=true
ANDROID_HOST=192.168.0.215
ANDROID_PORT=9100

# ===== Receipt =====
RECEIPT_WIDTH_PX=520

# ===== Timing =====
POLL_INTERVAL_SECONDS=5
COOLDOWN_SECONDS=120

# ===== General =====
TZ=Australia/Melbourne
